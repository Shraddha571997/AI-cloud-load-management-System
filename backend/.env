# ================================
# 🔐 Flask / JWT Configuration
# ================================
SECRET_KEY=your_super_secret_key_123
JWT_SECRET_KEY=your_jwt_secret_key_456

# ================================
# 🗄️ MongoDB (USE ATLAS - Recommended)
# ================================
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/cloud_load_management?retryWrites=true&w=majority

# ================================
# 📧 Mail Configuration (Gmail SMTP)
# ================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com

# ================================
# ⚙️ App Settings
# ================================
FLASK_ENV=production
PORT=5000

# ================================
# 📊 Redis (Optional - for Celery)
# ================================
REDIS_URL=redis://localhost:6379/0

# ================================
# ⏱️ Scheduler / Background Jobs
# ================================
SCHEDULER_API_ENABLED=true

# ================================
# 🧠 ML / System Settings
# ================================
MODEL_PATH=./models/
LOG_LEVEL=INFO
